# .ralphrc - Ralph project configuration
# Documentation: https://github.com/frankbria/ralph-claude-code

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================

PROJECT_NAME="cortex"
PROJECT_TYPE="python"

# =============================================================================
# LOOP SETTINGS
# =============================================================================

MAX_CALLS_PER_HOUR=200
CLAUDE_TIMEOUT_MINUTES=60
CLAUDE_OUTPUT_FORMAT="json"

# =============================================================================
# TOOL PERMISSIONS
# =============================================================================

ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,Bash(*),Agent(*),WebFetch(*),WebSearch(*),NotebookEdit(*),TodoWrite(*),AskUserQuestion(*),CronCreate(*),CronDelete(*),CronList(*),SendMessage(*),TaskOutput(*),TaskStop(*),TeamCreate(*),TeamDelete(*),Skill(*),ToolSearch(*),EnterPlanMode(*),ExitPlanMode(*),EnterWorktree(*),ExitWorktree(*),mcp__*"

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=48

# =============================================================================
# TASK SOURCES
# =============================================================================

TASK_SOURCES="local"

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================

CB_NO_PROGRESS_THRESHOLD=5
CB_SAME_ERROR_THRESHOLD=7
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_COOLDOWN_MINUTES=5
CB_AUTO_RESET=true

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

CLAUDE_MIN_VERSION="2.0.76"
RALPH_VERBOSE=true

# Use Opus 4.6 with extended thinking for highest quality implementation
CLAUDE_MODEL="claude-opus-4-6"

# Skip all permission prompts — Ralph runs autonomously
PERMISSION_MODE="bypassPermissions"
