# Cortex Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# LLM Configuration
# ============================================================================
# Mode: "remote" (gwhiz1), "local" (Ollama), "openai_compat"
CORTEX_LLM_MODE=remote

# Remote LLM (Qwen-3-8B on gwhiz1)
CORTEX_LLM_REMOTE_HOST=gwhiz1.cis.upenn.edu
CORTEX_LLM_REMOTE_PORT=8800
CORTEX_LLM_SSH_TUNNEL=true
CORTEX_LLM_SSH_USER=wangcy07
CORTEX_LLM_MODEL_NAME=qwen3-8b
CORTEX_LLM_MAX_TOKENS=1024
CORTEX_LLM_TEMPERATURE=0.3
CORTEX_LLM_TIMEOUT_SECONDS=10.0
CORTEX_LLM_FALLBACK_MODE=rule_based

# Local LLM (Ollama)
CORTEX_LLM_LOCAL_HOST=localhost
CORTEX_LLM_LOCAL_PORT=11434
CORTEX_LLM_LOCAL_MODEL=llama3.1:8b

# ============================================================================
# Capture Configuration
# ============================================================================
CORTEX_CAPTURE_DEVICE_ID=0
CORTEX_CAPTURE_FPS=30
CORTEX_CAPTURE_WIDTH=640
CORTEX_CAPTURE_HEIGHT=480
CORTEX_CAPTURE_MIN_BRIGHTNESS=50
CORTEX_CAPTURE_MAX_JITTER_PX=5.0
CORTEX_CAPTURE_FACE_LOST_TOLERANCE_FRAMES=5

# ============================================================================
# State Engine Configuration
# ============================================================================
# Hysteresis thresholds
CORTEX_STATE_ENTRY_THRESHOLD=0.85
CORTEX_STATE_EXIT_THRESHOLD=0.70

# Dwell times (seconds)
CORTEX_STATE_HYPER_DWELL_SECONDS=8
CORTEX_STATE_HYPO_DWELL_SECONDS=15
CORTEX_STATE_FLOW_DWELL_SECONDS=15

# EMA smoothing
CORTEX_STATE_EMA_ALPHA=0.3

# Overwhelm score weights (must sum to 1.0)
CORTEX_WEIGHT_PULSE_ELEVATION=0.20
CORTEX_WEIGHT_HRV_DROP=0.15
CORTEX_WEIGHT_BLINK_SUPPRESSION=0.12
CORTEX_WEIGHT_POSTURE_COLLAPSE=0.08
CORTEX_WEIGHT_MOUSE_THRASHING=0.15
CORTEX_WEIGHT_WINDOW_SWITCHING=0.15
CORTEX_WEIGHT_WORKSPACE_COMPLEXITY=0.15

# ============================================================================
# Intervention Configuration
# ============================================================================
# Confidence thresholds for intervention levels
CORTEX_INTERVENTION_OVERLAY_THRESHOLD=0.70
CORTEX_INTERVENTION_SIMPLIFIED_THRESHOLD=0.85
CORTEX_INTERVENTION_GUIDED_THRESHOLD=0.95

# Workspace complexity threshold
CORTEX_INTERVENTION_COMPLEXITY_THRESHOLD=0.6

# Cooldown and dismissal
CORTEX_INTERVENTION_COOLDOWN_SECONDS=60
CORTEX_INTERVENTION_QUIET_MODE_MINUTES=30
CORTEX_INTERVENTION_MAX_DISMISSALS=3
CORTEX_INTERVENTION_DISMISSAL_WINDOW_MINUTES=5
CORTEX_INTERVENTION_TIMEOUT_MINUTES=5

# Adaptive threshold adjustment
CORTEX_INTERVENTION_DISMISSAL_THRESHOLD_BUMP=0.05
CORTEX_INTERVENTION_DISMISSAL_DECAY_HOURS=1

# ============================================================================
# API Gateway Configuration
# ============================================================================
CORTEX_API_HOST=127.0.0.1
CORTEX_API_PORT=9472
CORTEX_WS_PORT=9473

# ============================================================================
# Telemetry Configuration
# ============================================================================
CORTEX_TELEMETRY_MOUSE_SAMPLE_HZ=60
CORTEX_TELEMETRY_DOWNSAMPLE_HZ=10
CORTEX_TELEMETRY_WINDOW_SECONDS=15

# ============================================================================
# Signal Processing Configuration
# ============================================================================
# rPPG settings
CORTEX_RPPG_WINDOW_SECONDS=10
CORTEX_RPPG_STRIDE_SECONDS=1
CORTEX_RPPG_BANDPASS_LOW=0.7
CORTEX_RPPG_BANDPASS_HIGH=3.5
CORTEX_RPPG_BANDPASS_ORDER=4
CORTEX_RPPG_WELCH_RESOLUTION=0.1

# Blink detection
CORTEX_BLINK_EAR_THRESHOLD=0.21
CORTEX_BLINK_EAR_RECOVERY=0.25
CORTEX_BLINK_MIN_FRAMES=3

# Posture detection
CORTEX_POSTURE_SHOULDER_DROP_THRESHOLD=0.15
CORTEX_POSTURE_FORWARD_LEAN_THRESHOLD=20.0

# ============================================================================
# Storage Configuration
# ============================================================================
CORTEX_STORAGE_PATH=./storage
CORTEX_SESSION_RETENTION_DAYS=7
CORTEX_FEATURE_RETENTION_DAYS=7
CORTEX_ERROR_RETENTION_DAYS=90

# ============================================================================
# Debug Configuration
# ============================================================================
CORTEX_DEBUG=false
CORTEX_DEBUG_CAPTURE=false
CORTEX_DEBUG_RPPG=false
CORTEX_DEBUG_STATE=false
CORTEX_DEBUG_LLM=false
CORTEX_LOG_LEVEL=INFO
