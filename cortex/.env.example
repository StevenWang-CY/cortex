# Cortex Configuration
# Copy to .env for development. Packaged builds should prefer macOS Keychain.

# ============================================================================
# LLM Configuration — Anthropic SDK only (v0.2.0+)
# ============================================================================
# Provider transport. One of: bedrock (default), vertex, direct.
# The value is mirrored into ANTHROPIC_PROVIDER at startup so the SDK
# picks the right backend.
CORTEX_LLM__PROVIDER=bedrock

# AWS Bedrock transport. Bearer token lives in macOS Keychain (BYOK):
#   security add-generic-password -s cortex.bedrock -a bearer_token -w YOUR_TOKEN
# Set CORTEX_LLM__USE_KEYCHAIN=false to use a literal AWS_BEARER_TOKEN_BEDROCK env var.
CORTEX_LLM__BEDROCK__AWS_REGION=us-east-2
CORTEX_LLM__BEDROCK__KEYCHAIN_SERVICE=cortex.bedrock
CORTEX_LLM__BEDROCK__KEYCHAIN_ACCOUNT=bearer_token
CORTEX_LLM__USE_KEYCHAIN=true

# Logical model tiers (resolved to provider-specific IDs at call time).
CORTEX_LLM__MODEL_DEFAULT=claude-sonnet-4-6
CORTEX_LLM__MODEL_FAST=claude-haiku-4-5
CORTEX_LLM__MODEL_DEEP=claude-opus-4-7

CORTEX_LLM__MAX_TOKENS=1024
CORTEX_LLM__TEMPERATURE=0.3
CORTEX_LLM__TIMEOUT_SECONDS=30.0
# Fallback strategy when every provider fails. ``rule_based`` (default)
# returns a deterministic plan; ``direct_anthropic`` retries via the
# direct API if ANTHROPIC_API_KEY is provisioned.
CORTEX_LLM__FALLBACK_MODE=rule_based

# Removed providers (v0.2.0+): Azure OpenAI, self-hosted Qwen, local
# Ollama. The env vars CORTEX_LLM__MODE, CORTEX_LLM__AZURE__*,
# CORTEX_LLM__REMOTE__*, CORTEX_LLM__LOCAL__*, CORTEX_LLM__MODEL_NAME
# are no longer read by the code; legacy 0.1.x .env files boot cleanly
# because the validator maps stale values to the rule-based fallback.

# ============================================================================
# Capture Configuration
# ============================================================================
# Leave blank for automatic camera selection (recommended on macOS)
# CORTEX_CAPTURE__DEVICE_ID=0
CORTEX_CAPTURE__FPS=30
CORTEX_CAPTURE__WIDTH=640
CORTEX_CAPTURE__HEIGHT=480
CORTEX_CAPTURE__MIN_BRIGHTNESS=50
CORTEX_CAPTURE__MAX_JITTER_PX=5.0
CORTEX_CAPTURE__FACE_LOST_TOLERANCE_FRAMES=5

# ============================================================================
# State Engine Configuration
# ============================================================================
CORTEX_STATE__ENTRY_THRESHOLD=0.85
CORTEX_STATE__EXIT_THRESHOLD=0.70
CORTEX_STATE__HYPER_DWELL_SECONDS=30
CORTEX_STATE__HYPO_DWELL_SECONDS=60
CORTEX_STATE__FLOW_DWELL_SECONDS=120
CORTEX_STATE__EMA_ALPHA=0.3
CORTEX_STATE__ML_ENABLED=false
CORTEX_STATE__ML_MIN_LABELED_EPISODES=30
CORTEX_STATE__ML_ALPHA_MAX=0.7
CORTEX_STATE__ML_ALPHA_FULL_AT_EPISODES=150
CORTEX_STATE__WEIGHTS__PULSE_ELEVATION=0.20
CORTEX_STATE__WEIGHTS__HRV_DROP=0.15
CORTEX_STATE__WEIGHTS__BLINK_SUPPRESSION=0.12
CORTEX_STATE__WEIGHTS__POSTURE_COLLAPSE=0.08
CORTEX_STATE__WEIGHTS__MOUSE_THRASHING=0.15
CORTEX_STATE__WEIGHTS__WINDOW_SWITCHING=0.15
CORTEX_STATE__WEIGHTS__WORKSPACE_COMPLEXITY=0.15

# ============================================================================
# Intervention Configuration
# ============================================================================
CORTEX_INTERVENTION__OVERLAY_THRESHOLD=0.70
CORTEX_INTERVENTION__SIMPLIFIED_THRESHOLD=0.85
CORTEX_INTERVENTION__GUIDED_THRESHOLD=0.95
CORTEX_INTERVENTION__COMPLEXITY_THRESHOLD=0.6
CORTEX_INTERVENTION__COOLDOWN_SECONDS=60
CORTEX_INTERVENTION__QUIET_MODE_MINUTES=30
CORTEX_INTERVENTION__MAX_DISMISSALS=3
CORTEX_INTERVENTION__DISMISSAL_WINDOW_MINUTES=5
CORTEX_INTERVENTION__TIMEOUT_MINUTES=5
CORTEX_INTERVENTION__DISMISSAL_THRESHOLD_BUMP=0.05
CORTEX_INTERVENTION__DISMISSAL_DECAY_HOURS=1
CORTEX_INTERVENTION__RECEPTIVITY_ENFORCED=true
CORTEX_INTERVENTION__RECEPTIVITY_TYPING_BURST_SECONDS=10.0
CORTEX_INTERVENTION__RECEPTIVITY_BLOCK_FULLSCREEN=true
CORTEX_INTERVENTION__RECEPTIVITY_BLOCK_IF_MIC_ACTIVE=true
CORTEX_INTERVENTION__RECEPTIVITY_WORK_HOURS_START=7
CORTEX_INTERVENTION__RECEPTIVITY_WORK_HOURS_END=22
CORTEX_INTERVENTION__ADAPTIVE_THRESHOLD_ENABLED=true
CORTEX_INTERVENTION__ADAPTIVE_THRESHOLD_MIN=0.75
CORTEX_INTERVENTION__ADAPTIVE_THRESHOLD_MAX=0.95
CORTEX_INTERVENTION__DISMISSAL_MODEL_ENABLED=true
CORTEX_INTERVENTION__DISMISSAL_MODEL_THRESHOLD=0.6

# ----------------------------------------------------------------------------
# P0 §3.7 — Biology-driven break (BREAK_RECOMMENDATION + take_biology_break)
# ----------------------------------------------------------------------------
CORTEX_INTERVENTION__ENABLE_BIOLOGY_BREAK=true
CORTEX_INTERVENTION__BIOLOGY_BREAK_AUDIO_MUTE_AFTER_MIC_SECONDS=300.0

# ----------------------------------------------------------------------------
# P0 §3.10 — Auto-armed distraction blocking on sustained HYPER
# Default OFF. Users opt in from Settings → Focus protection, which
# also promotes the ``distraction_block`` consent class to AUTONOMOUS_ACT.
# ----------------------------------------------------------------------------
CORTEX_INTERVENTION__ENABLE_AUTO_DISTRACTION_BLOCK=false
CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_CONFIDENCE=0.85
CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_DWELL_SECONDS=30.0
CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_EXIT_SECONDS=300.0
CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_SESSION_MINUTES=20
CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_PRESET=developer
# Use commas; pydantic_settings splits on `,` for list[str] env vars.
# CORTEX_INTERVENTION__AUTO_DISTRACTION_BLOCK_CUSTOM_DOMAINS=hn.ycombinator.com,news.ycombinator.com

# ----------------------------------------------------------------------------
# P0 §3.12 — OS-level notification fallback when the desktop dashboard
# is not the focused window. macOS UN + Chrome action badge + VS Code
# status-bar pulse. Bodies carry only LLM headlines (no biometrics).
# ----------------------------------------------------------------------------
CORTEX_INTERVENTION__ENABLE_OS_NOTIFICATIONS=true

# ============================================================================
# API Configuration
# ============================================================================
CORTEX_API__HOST=127.0.0.1
CORTEX_API__PORT=9472
CORTEX_API__WS_PORT=9473

# ============================================================================
# Telemetry Configuration
# ============================================================================
CORTEX_TELEMETRY__MOUSE_SAMPLE_HZ=60
CORTEX_TELEMETRY__DOWNSAMPLE_HZ=10
CORTEX_TELEMETRY__WINDOW_SECONDS=15

# ============================================================================
# Signal Configuration
# ============================================================================
CORTEX_SIGNAL__RPPG__WINDOW_SECONDS=10
CORTEX_SIGNAL__RPPG__STRIDE_SECONDS=1
CORTEX_SIGNAL__RPPG__BACKEND=pos
CORTEX_SIGNAL__RPPG__MODEL_PATH=cortex/models/tscan.onnx
CORTEX_SIGNAL__RPPG__BANDPASS_LOW=0.7
CORTEX_SIGNAL__RPPG__BANDPASS_HIGH=3.5
CORTEX_SIGNAL__RPPG__BANDPASS_ORDER=4
CORTEX_SIGNAL__RPPG__WELCH_RESOLUTION=0.1
CORTEX_SIGNAL__RPPG__NSQI_THRESHOLD=0.293
CORTEX_SIGNAL__RPPG__MIN_CARDIAC_SNR_DB=2.0
CORTEX_SIGNAL__RPPG__MIN_RESP_SNR_DB=1.5
CORTEX_SIGNAL__RPPG__MAX_FACE_LOSS_RATIO=0.2
CORTEX_SIGNAL__RPPG__MAX_HEAD_JITTER_DEG=7.5
CORTEX_SIGNAL__RPPG__HRV_MIN_WINDOW_SECONDS=60
CORTEX_SIGNAL__RPPG__HRV_MIN_VALID_IBI=30
CORTEX_SIGNAL__BLINK__EAR_THRESHOLD=0.21
CORTEX_SIGNAL__BLINK__EAR_RECOVERY=0.25
CORTEX_SIGNAL__BLINK__MIN_FRAMES=3
CORTEX_SIGNAL__BLINK__PERCLOS_THRESHOLD=0.2
CORTEX_SIGNAL__BLINK__PERSONALIZE_EAR_PERCENTILE=0.15
CORTEX_SIGNAL__POSTURE__SHOULDER_DROP_THRESHOLD=0.15
CORTEX_SIGNAL__POSTURE__FORWARD_LEAN_THRESHOLD=20.0

# ============================================================================
# Evaluation / AMIP
# ============================================================================
CORTEX_EVAL__POLICY=amip
CORTEX_EVAL__AMIP__ENABLED=true
CORTEX_EVAL__AMIP__TAU0=1.0
CORTEX_EVAL__AMIP__TAU_MIN=0.1
CORTEX_EVAL__AMIP__EPSILON_EXPLORE=0.05
CORTEX_EVAL__AMIP__EPSILON_EXPLORE_AFTER_500=0.01
CORTEX_EVAL__AMIP__SAFETY_FLOOR_STRESS_RATIO=1.0
CORTEX_EVAL__AMIP__REWARD_WINDOW_SECONDS=300
CORTEX_EVAL__CAUSAL_REPORT__ENABLED=true
CORTEX_EVAL__CAUSAL_REPORT__BOOTSTRAP_SAMPLES=300
CORTEX_EVAL__CAUSAL_REPORT__NIGHTLY_HOUR_LOCAL=2

# ============================================================================
# Storage / Debug
# ============================================================================
CORTEX_STORAGE__PATH=./storage
CORTEX_STORAGE__SESSION_RETENTION_DAYS=7
CORTEX_STORAGE__FEATURE_RETENTION_DAYS=7
CORTEX_STORAGE__ERROR_RETENTION_DAYS=90
CORTEX_DEBUG__ENABLED=false
CORTEX_DEBUG__CAPTURE=false
CORTEX_DEBUG__RPPG=false
CORTEX_DEBUG__STATE=false
CORTEX_DEBUG__LLM=false
CORTEX_LOGGING__LEVEL=INFO
