# Cortex Configuration
# Copy to .env for development. Packaged builds should prefer macOS Keychain.

# ============================================================================
# LLM Configuration
# ============================================================================
CORTEX_LLM__MODE=azure
CORTEX_LLM__TEMPERATURE=0.3
CORTEX_LLM__TIMEOUT_SECONDS=10.0
CORTEX_LLM__FALLBACK_MODE=local_ollama

# Azure OpenAI
CORTEX_LLM__AZURE__ENDPOINT=https://your-resource.openai.azure.com/
CORTEX_LLM__AZURE__API_KEY=
CORTEX_LLM__AZURE__API_VERSION=2025-01-01-preview
CORTEX_LLM__AZURE__DEPLOYMENT_NAME=gpt-5-mini
CORTEX_LLM__AZURE__REASONING_DEPLOYMENT_NAME=gpt-5-mini
CORTEX_LLM__AZURE__MAX_COMPLETION_TOKENS=1024
CORTEX_LLM__AZURE__USE_KEYCHAIN=true
CORTEX_LLM__AZURE__KEYCHAIN_SERVICE=cortex.azure_openai
CORTEX_LLM__AZURE__KEYCHAIN_ACCOUNT=default

# Remote LLM (optional — for self-hosted vLLM/SGLang server)
CORTEX_LLM__REMOTE__HOST=
CORTEX_LLM__REMOTE__PORT=8800
CORTEX_LLM__REMOTE__SSH_TUNNEL=true
CORTEX_LLM__REMOTE__SSH_USER=
CORTEX_LLM__MODEL_NAME=qwen3-8b
CORTEX_LLM__MAX_TOKENS=1024

# Local LLM (Ollama fallback)
CORTEX_LLM__LOCAL__HOST=localhost
CORTEX_LLM__LOCAL__PORT=11434
CORTEX_LLM__LOCAL__MODEL=llama3.1:8b

# ============================================================================
# Capture Configuration
# ============================================================================
# Leave blank for automatic camera selection (recommended on macOS)
# CORTEX_CAPTURE__DEVICE_ID=0
CORTEX_CAPTURE__FPS=30
CORTEX_CAPTURE__WIDTH=640
CORTEX_CAPTURE__HEIGHT=480
CORTEX_CAPTURE__MIN_BRIGHTNESS=50
CORTEX_CAPTURE__MAX_JITTER_PX=5.0
CORTEX_CAPTURE__FACE_LOST_TOLERANCE_FRAMES=5

# ============================================================================
# State Engine Configuration
# ============================================================================
CORTEX_STATE__ENTRY_THRESHOLD=0.85
CORTEX_STATE__EXIT_THRESHOLD=0.70
CORTEX_STATE__HYPER_DWELL_SECONDS=8
CORTEX_STATE__HYPO_DWELL_SECONDS=15
CORTEX_STATE__FLOW_DWELL_SECONDS=15
CORTEX_STATE__EMA_ALPHA=0.3
CORTEX_STATE__WEIGHTS__PULSE_ELEVATION=0.20
CORTEX_STATE__WEIGHTS__HRV_DROP=0.15
CORTEX_STATE__WEIGHTS__BLINK_SUPPRESSION=0.12
CORTEX_STATE__WEIGHTS__POSTURE_COLLAPSE=0.08
CORTEX_STATE__WEIGHTS__MOUSE_THRASHING=0.15
CORTEX_STATE__WEIGHTS__WINDOW_SWITCHING=0.15
CORTEX_STATE__WEIGHTS__WORKSPACE_COMPLEXITY=0.15

# ============================================================================
# Intervention Configuration
# ============================================================================
CORTEX_INTERVENTION__OVERLAY_THRESHOLD=0.70
CORTEX_INTERVENTION__SIMPLIFIED_THRESHOLD=0.85
CORTEX_INTERVENTION__GUIDED_THRESHOLD=0.95
CORTEX_INTERVENTION__COMPLEXITY_THRESHOLD=0.6
CORTEX_INTERVENTION__COOLDOWN_SECONDS=60
CORTEX_INTERVENTION__QUIET_MODE_MINUTES=30
CORTEX_INTERVENTION__MAX_DISMISSALS=3
CORTEX_INTERVENTION__DISMISSAL_WINDOW_MINUTES=5
CORTEX_INTERVENTION__TIMEOUT_MINUTES=5
CORTEX_INTERVENTION__DISMISSAL_THRESHOLD_BUMP=0.05
CORTEX_INTERVENTION__DISMISSAL_DECAY_HOURS=1

# ============================================================================
# API Configuration
# ============================================================================
CORTEX_API__HOST=127.0.0.1
CORTEX_API__PORT=9472
CORTEX_API__WS_PORT=9473

# ============================================================================
# Telemetry Configuration
# ============================================================================
CORTEX_TELEMETRY__MOUSE_SAMPLE_HZ=60
CORTEX_TELEMETRY__DOWNSAMPLE_HZ=10
CORTEX_TELEMETRY__WINDOW_SECONDS=15

# ============================================================================
# Signal Configuration
# ============================================================================
CORTEX_SIGNAL__RPPG__WINDOW_SECONDS=10
CORTEX_SIGNAL__RPPG__STRIDE_SECONDS=1
CORTEX_SIGNAL__RPPG__BANDPASS_LOW=0.7
CORTEX_SIGNAL__RPPG__BANDPASS_HIGH=3.5
CORTEX_SIGNAL__RPPG__BANDPASS_ORDER=4
CORTEX_SIGNAL__RPPG__WELCH_RESOLUTION=0.1
CORTEX_SIGNAL__BLINK__EAR_THRESHOLD=0.21
CORTEX_SIGNAL__BLINK__EAR_RECOVERY=0.25
CORTEX_SIGNAL__BLINK__MIN_FRAMES=3
CORTEX_SIGNAL__POSTURE__SHOULDER_DROP_THRESHOLD=0.15
CORTEX_SIGNAL__POSTURE__FORWARD_LEAN_THRESHOLD=20.0

# ============================================================================
# Storage / Debug
# ============================================================================
CORTEX_STORAGE__PATH=./storage
CORTEX_STORAGE__SESSION_RETENTION_DAYS=7
CORTEX_STORAGE__FEATURE_RETENTION_DAYS=7
CORTEX_STORAGE__ERROR_RETENTION_DAYS=90
CORTEX_DEBUG__ENABLED=false
CORTEX_DEBUG__CAPTURE=false
CORTEX_DEBUG__RPPG=false
CORTEX_DEBUG__STATE=false
CORTEX_DEBUG__LLM=false
CORTEX_LOGGING__LEVEL=INFO
