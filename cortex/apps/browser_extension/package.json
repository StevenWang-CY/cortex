{
  "name": "cortex-browser-extension",
  "displayName": "Cortex — Somatic Workspace Engine",
  "version": "0.1.0",
  "description": "Real-time biofeedback workspace engine for Chrome.",
  "scripts": {
    "dev": "plasmo dev",
    "dev:chrome": "plasmo dev",
    "dev:edge": "plasmo dev --target=edge-mv3",
    "build": "plasmo build",
    "build:chrome": "plasmo build",
    "build:edge": "plasmo build --target=edge-mv3",
    "package": "plasmo package",
    "package:chrome": "plasmo package",
    "package:edge": "plasmo build --target=edge-mv3"
  },
  "dependencies": {
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.0",
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting",
      "tabs",
      "tabGroups",
      "storage",
      "alarms",
      "bookmarks",
      "webNavigation"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
