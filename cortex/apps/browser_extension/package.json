{
  "name": "cortex-browser-extension",
  "displayName": "Cortex — Somatic Workspace Engine",
  "version": "0.2.1",
  "description": "Real-time biofeedback workspace engine for Chrome.",
  "scripts": {
    "dev": "plasmo dev",
    "dev:chrome": "plasmo dev",
    "dev:edge": "plasmo dev --target=edge-mv3",
    "build": "plasmo build",
    "build:chrome": "plasmo build",
    "build:edge": "plasmo build --target=edge-mv3",
    "package": "plasmo package",
    "package:chrome": "plasmo package",
    "package:edge": "plasmo build --target=edge-mv3",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@types/chrome": "^0.1.42",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.3.0",
    "vitest": "^2.1.5"
  },
  "manifest": {
    "key": "",
    "permissions": [
      "activeTab",
      "scripting",
      "tabs",
      "tabGroups",
      "storage",
      "alarms",
      "bookmarks",
      "webNavigation",
      "nativeMessaging"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "assets/fonts/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  }
}
