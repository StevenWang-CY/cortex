{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    },
    "default_popup": "./popup.html"
  },
  "version": "0.1.0",
  "name": "DEV | Cortex — Somatic Workspace Engine",
  "description": "Real-time biofeedback workspace engine for Chrome.",
  "background": {
    "service_worker": "./static/background/index.ts"
  },
  "chrome_url_overrides": {
    "newtab": "./newtab.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "bookmarks",
    "webNavigation"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "../contents/ambient.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "static/content.tsx"
      ]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
