{
  "name": "cortex-somatic",
  "displayName": "Cortex — Somatic Workspace Engine",
  "description": "Real-time biofeedback workspace engine that detects cognitive overwhelm and restructures your VS Code environment.",
  "version": "0.2.2",
  "publisher": "cortex",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "dependencies": {
    "ws": "^8.20.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "cortex.getActiveFile",
        "title": "Cortex: Get Active File Info"
      },
      {
        "command": "cortex.getDiagnostics",
        "title": "Cortex: Get Current File Diagnostics"
      },
      {
        "command": "cortex.getSymbolAtCursor",
        "title": "Cortex: Get Symbol at Cursor"
      },
      {
        "command": "cortex.foldExcept",
        "title": "Cortex: Fold Except Range"
      },
      {
        "command": "cortex.unfoldAll",
        "title": "Cortex: Unfold All"
      },
      {
        "command": "cortex.restoreFoldState",
        "title": "Cortex: Restore Fold State"
      },
      {
        "command": "cortex.showPanel",
        "title": "Cortex: Show Intervention Panel"
      },
      {
        "command": "cortex.connect",
        "title": "Cortex: Connect to Daemon"
      },
      {
        "command": "cortex.disconnect",
        "title": "Cortex: Disconnect from Daemon"
      },
      {
        "command": "cortex.disableInlineSuggestions",
        "title": "Cortex: Disable Inline Suggestions (HYPER mode)"
      },
      {
        "command": "cortex.enableInlineSuggestions",
        "title": "Cortex: Enable Inline Suggestions (FLOW mode)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cortex-sidebar",
          "title": "Cortex",
          "icon": "media/cortex.svg"
        }
      ]
    },
    "views": {
      "cortex-sidebar": [
        {
          "type": "webview",
          "id": "cortex.interventionPanel",
          "name": "Cortex Intervention"
        }
      ]
    },
    "configuration": {
      "title": "Cortex",
      "properties": {
        "cortex.daemonUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:9473",
          "description": "WebSocket URL of the Cortex daemon"
        },
        "cortex.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to daemon on startup"
        },
        "cortex.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Cortex state in the status bar"
        },
        "cortex.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose diagnostic logs from the Cortex extension (COPILOT_THROTTLE tracer lines, WS reconnect noise). Off by default."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest --testPathPattern='src/__tests__'"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/__tests__"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "testPathIgnorePatterns": ["/__mocks__/"],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__tests__/__mocks__/vscode.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "diagnostics": false,
        "isolatedModules": true
      }]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.0"
  }
}
