# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.venv/

# Environment & secrets
.env

# OS
.DS_Store

# Dependencies
node_modules/

# Tool configs
.ralph/
.claude/
.ralphrc
.vscode/
CLAUDE.md
# CHANGELOG.md is tracked starting at Phase J — it's the user-facing
# audit close-out summary at the release boundary.

# VS Code extension compiled output
cortex/apps/vscode_extension/out/

# Runtime artifacts
.cortex_launch.sh
*.log
cortex_daemon.log

# Compiled binaries
CortexDaemon.app/

# Browser extension build artifacts
.plasmo/
cortex/apps/browser_extension/.plasmo/
cortex/apps/browser_extension/build/

# Audit-2 hygiene: only ``pnpm-lock.yaml`` is tracked; a developer
# running ``npm install`` (build script fallback) materialises a
# ``package-lock.json`` we explicitly don't want to commit.
cortex/apps/browser_extension/package-lock.json

# P1-15: VS Code extension package-lock.json — mirrors the browser_extension
# exclusion above. The vscode_extension uses npm/vsce; package-lock.json is
# generated on the developer's machine and must not be committed.
cortex/apps/vscode_extension/package-lock.json

# VS Code extension build artifacts
*.vsix

# Cortex storage (keep directory structure via .gitkeep)
storage/sessions/*
storage/cache/*
storage/baselines/*
storage/logs/*
storage/exports/*
storage/models/*
storage/.onboarding_complete
!storage/**/.gitkeep
